# ─── DB 연결 ───────────────────────────────────────────────
# PostgreSQL 연결 문자열 (실제 값으로 교체)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/sourcing_db

# 동기 연결 (Alembic 마이그레이션용)
SYNC_DATABASE_URL=postgresql://user:password@localhost:5432/sourcing_db

# ─── 앱 설정 ───────────────────────────────────────────────
APP_ENV=development          # development | production
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
DB_POOL_SIZE=3
DB_MAX_OVERFLOW=2

# Hybrid search MVP
# Keep disabled until the pgvector migration is applied and local embeddings are backfilled.
HYBRID_SEARCH_ENABLED=false
# Render production: remote. Local development/backfill: local.
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=intfloat/multilingual-e5-small
LOCAL_EMBEDDING_DEVICE=cpu
EMBEDDING_DIMENSIONS=384
# Required only when EMBEDDING_PROVIDER=remote.
EMBEDDING_SERVICE_URL=https://YOUR-SPACE.hf.space
EMBEDDING_SERVICE_TOKEN=replace-with-the-same-random-secret-as-the-space
EMBEDDING_SERVICE_TIMEOUT=30
HYBRID_CANDIDATE_LIMIT=1000
HYBRID_SIMILARITY_THRESHOLD=0.90
QUERY_EMBEDDING_CACHE_TTL=300
