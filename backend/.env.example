# ─── DB 연결 ───────────────────────────────────────────────
# PostgreSQL 연결 문자열 (실제 값으로 교체)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/sourcing_db

# 동기 연결 (Alembic 마이그레이션용)
SYNC_DATABASE_URL=postgresql://user:password@localhost:5432/sourcing_db

# ─── 앱 설정 ───────────────────────────────────────────────
APP_ENV=development          # development | production
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Hybrid search MVP
# Keep disabled until the pgvector migration is applied and local embeddings are backfilled.
HYBRID_SEARCH_ENABLED=false
# EMBEDDING_PROVIDER=local loads the model in this process - fine for local
# use (e.g. running backfill_product_embeddings.py on your own machine).
# In production (Render), set EMBEDDING_PROVIDER=remote and
# EMBEDDING_SERVICE_URL to the deployed embedding_service's URL instead -
# this app also carries pandas/SQLAlchemy/openpyxl, and a 512MB deployment
# doesn't have room left to also hold the embedding model in this process.
EMBEDDING_PROVIDER=local
# EMBEDDING_SERVICE_URL=https://sourcing-embedding-xxxx.onrender.com
LOCAL_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSIONS=384
HYBRID_CANDIDATE_LIMIT=300
HYBRID_SIMILARITY_THRESHOLD=0.90
QUERY_EMBEDDING_CACHE_TTL=300
